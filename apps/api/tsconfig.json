{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "module": "CommonJS",
    "paths": {
      "@ignara/sharedtypes": ["packages/sharedtypes/dist/index.d.ts"],
      "@ignara/sharedtypes/*": ["packages/sharedtypes/dist/*"]
    },
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "strictPropertyInitialization": false
  },
  "include": ["src/**/*.ts"]
}
