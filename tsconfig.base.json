{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@ignara/sharedtypes": ["packages/sharedtypes/src/index.ts"],
      "@ignara/sharedtypes/*": ["packages/sharedtypes/src/*"]
    }
  }
}
